{
  "name": "weixin-router",
  "version": "0.1.0",
  "description": "WeChat router for Codex and Claude ACP agents",
  "license": "MIT",
  "type": "module",
  "bin": {
    "weixin-router": "dist/main.mjs"
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DawnJson/weixincli.git"
  },
  "homepage": "https://github.com/DawnJson/weixincli#readme",
  "bugs": {
    "url": "https://github.com/DawnJson/weixincli/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "acp",
    "agent",
    "claude",
    "codex",
    "wechat",
    "weixin"
  ],
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.17.0",
    "@zed-industries/claude-agent-acp": "^0.23.0",
    "@zed-industries/codex-acp": "^0.10.0",
    "cross-spawn": "^7.0.6",
    "qrcode-terminal": "0.12.0"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run build",
    "pretest": "corepack pnpm --filter weixin-router build",
    "test": "node test/router-agent.test.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.8.0"
  }
}
